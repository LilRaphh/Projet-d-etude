# Copier ce fichier en .env et remplir les valeurs
# NE PAS committer le fichier .env

# Obligatoire — générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Optionnel — si absent, dérivé automatiquement de SECRET_KEY
# FERNET_KEY=

# Port d'écoute (défaut 5000)
PORT=5000

# Dossier de logs (optionnel — si absent, log en console uniquement)
# LOG_DIR=./logs

# Modèle Claude (défaut claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Nombre d'items par page (défaut 24)
# ITEMS_PER_PAGE=24

# Cache backend (SimpleCache par défaut, RedisCache en production)
# CACHE_TYPE=SimpleCache
# REDIS_URL=redis://localhost:6379
